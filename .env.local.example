# Supabase (필수)
# https://supabase.com/dashboard 프로젝트 설정에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 관리자 로그인 (/login)
# - 로컬(NODE_ENV=development): 미설정 시에만 기본 0000 (편의용)
# - 프로덕션: 반드시 설정. 미설정 시 로그인 불가
ADMIN_ACCESS_CODE=0000

# OpenAI (전체 AI 리포트용, 선택)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Google Sheets — 필터된 판매 데이터 "Sheets에 추가" (선택)
# 1) GCP에서 서비스 계정 생성 → JSON 키 다운로드
# 2) 스프레드시트를 해당 서비스 계정 이메일(…@….iam.gserviceaccount.com)에 편집자로 공유
# 3) 스프레드시트 URL의 /d/스프레드시트_ID/edit 에서 ID 복사
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
# 탭 이름(기본 Sheet1). 한글 탭이면 그 이름 그대로
# GOOGLE_SHEETS_TAB=Sheet1
# 아래 둘 중 하나: 한 줄 JSON(따옴표 이스케이프) 또는 Base64 인코딩된 JSON 전체
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii4uLn0=
